# ── MySQL ──
MYSQL_USER=citicup_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_ROOT_PASSWORD=your_root_password

# ── API Keys ──
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
OIL_PRICE_API_TOKEN=xxxxxxxxxxxxxxxx

# ── Model Service ──
USE_STUB=0

# ── Agent Service ──
STAGEX2_MODEL=deepseek-chat
STAGEX2_BASE_URL=https://api.deepseek.com

# ── Proxy (for Oil Price API, leave empty if not needed) ──
APP_PROXY_HOST=127.0.0.1
APP_PROXY_PORT=7890
